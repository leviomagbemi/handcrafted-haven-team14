generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

model User {
  id        String   @id @default(cuid())
  name      String
  email     String   @unique
  password  String
  role      Role     @default(BUYER)
  createdAt DateTime @default(now())
  products  Product[]
  reviews   Review[]
}

model Product {
  id          String   @id @default(cuid())
  title       String
  description String
  price       Float
  images      String[] // JSON array of image URLs
  category    String
  sellerId    String
  seller      User     @relation(fields: [sellerId], references: [id])
  reviews     Review[]
  createdAt   DateTime @default(now())
}

model Review {
  id        String   @id @default(cuid())
  rating    Int
  comment   String?
  productId String
  userId    String
  product   Product  @relation(fields: [productId], references: [id])
  user      User     @relation(fields: [userId], references: [id])
  createdAt DateTime @default(now())
}

enum Role {
  BUYER
  SELLER
  ADMIN
}